# 复制为 .env 并填入真实值（.env 已被 .gitignore 忽略）

# ---- GitHub（只读 public 即可）----
GITHUB_TOKEN=

# ---- 飞书自建应用（custom app）----
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 私聊推给你本人：open_id(ou_...) 最稳；也可用 email / mobile（同时把 TYPE 改掉）
FEISHU_RECEIVE_ID=
FEISHU_RECEIVE_ID_TYPE=open_id

# ---- LLM（只需填当前 provider 的 key；provider/model 在 config.yaml）----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OLLAMA_BASE_URL=
